generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String
  price       Int
  imageUrl    String
  description String?
  materials   String[]
  inventory   Int      @default(0)
  featured    Boolean  @default(false)
  status      String   @default("active")
  stockTag    String?
  cycle       String?
  material    String?
  size        String?
  care        String?
  note        String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Section {
  id          String   @id @default(cuid())
  type        String
  title       String
  subtitle    String?
  description String?
  imageUrl    String?
  href        String?
  ctaLabel    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Page {
  slug        String   @id
  title       String
  eyebrow     String?
  description String?
  status      String   @default("published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id           String   @id @default(cuid())
  customer     String
  email        String   @default("")
  shipping     String   @default("")
  payment      String   @default("")
  productId    String   @default("")
  productName  String   @default("")
  quantity     Int      @default(1)
  total        Int
  status       String   @default("pending")
  note         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteConfig {
  id             String @id @default("config")
  siteName       String @default("LazyJam")
  tagline        String?
  announcement   String?
  contactEmail   String?
  instagram      String?
  updatedAt      DateTime @updatedAt
}

model PaymentConfig {
  id             String @id @default("payment")
  config         Json
  updatedAt      DateTime @updatedAt
}